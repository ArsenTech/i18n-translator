{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "I18N Translator",
  "version": "0.3.1",
  "identifier": "com.arsentech.i18n-translator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "I18N Translator",
        "width": 1280,
        "height": 800,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "publisher": "ArsenTech",
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "compression": "zlib",
        "installMode": "both",
        "sidebarImage": "assets/sidebar-image.bmp",
        "headerImage": "assets/header-image.bmp",
        "installerIcon": "assets/installer.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/ArsenTech/i18n-translator/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhGRjcxNDRGOTJEQkQ2RjQKUldUMDF0dVNUeFQzai9pV2NNa0xPNXZjaXk3Yml6Zm1MaGxIYnIrdGljSWZTRk5oYXVURzdnZTgK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
